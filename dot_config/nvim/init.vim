" ========== 缩进 ==========
set expandtab        " 使用空格代替 Tab
set tabstop=4        " Tab 宽度为 4 个空格
set shiftwidth=4     " 缩进宽度为 4 个空格
set softtabstop=4    " 退格键删除 4 个空格
set smartindent      " 智能缩进

" ========== 语法高亮 ==========
syntax on            " 启用语法高亮
set termguicolors    " 使用真彩色

" ========== 行号 ==========
set number           " 显示行号
set relativenumber   " 显示相对行号
